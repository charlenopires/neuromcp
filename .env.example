# Conexão Neo4j (bate com o docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neurodivergencia123

# Embeddings para o GraphRAG
#   auto                  -> tenta sentence-transformers, cai p/ hashing (offline)
#   sentence-transformers -> semântico local (requer: uv sync --extra embeddings)
#   ollama                -> semântico local via Ollama (nomic-embed-text)
#   hashing               -> fallback determinístico NÃO-semântico (testes/CI)
NEURO_EMBEDDING_PROVIDER=auto
# Dimensão do índice vetorial no Neo4j (MiniLM=384, nomic-embed-text=768, hashing=384)
NEURO_EMBEDDING_DIM=384

# Só para o provedor ollama
# OLLAMA_HOST=http://localhost:11434
